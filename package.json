{
  "name": "@t3-oss/env-root",
  "packageManager": "bun@1.3.1",
  "engines": {
    "node": "^24.0.0",
    "bun": "^1.3.0"
  },
  "private": true,
  "type": "module",
  "workspaces": [
    "docs",
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "build": "vp run --filter @t3-oss/env* build",
    "clean": "vp run -r clean && rm -rf node_modules",
    "dev": "vp run --parallel --filter @t3-oss/env* build --watch",
    "fmt": "vp fmt . --write",
    "lint": "vp lint --deny-warnings",
    "lint:fix": "vp lint --fix --deny-warnings && vp fmt . --write",
    "test": "vp test",
    "test:run": "vp test run",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@types/bun": "^1.3.2",
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "vite-plus": "catalog:"
  },
  "catalog": {
    "vite-plus": "latest"
  }
}
