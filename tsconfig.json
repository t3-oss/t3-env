{
  "compilerOptions": {
    // Build Performance
    "incremental": true,
    "composite": true,
    "libReplacement": false,
    "tsBuildInfoFile": "${configDir}/.cache/tsbuildinfo.json",

    // Module System
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "isolatedModules": true,
    "isolatedDeclarations": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,

    // Import Resolution
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@t3-oss/env-core": ["./packages/core/src/index.ts"],
      "@t3-oss/env-core/presets-arktype": ["./packages/core/src/presets-arktype.ts"],
      "@t3-oss/env-core/presets-zod": ["./packages/core/src/presets-zod.ts"],
      "@t3-oss/env-core/presets-valibot": ["./packages/core/src/presets-valibot.ts"],
    },

    // Type Safety
    "strict": true,
    "noImplicitOverride": true,
    // "noUncheckedIndexedAccess": true,

    // Development
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
  },
  "include": ["./**/*.ts"],
  "exclude": ["./node_modules", "./packages"],
}
